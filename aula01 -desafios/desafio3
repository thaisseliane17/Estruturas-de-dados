//remove pelo valor

struct no *remove_value(struct no *Lista, int value){
    struct no *atual = Lista;
    struct no *anterior = NULL;
    
//vereficaçao se o valor pedido e o primeiro no
    while(atual != NULL){
        if(atual->info == value){
            if(anterior == NULL){
                Lista = atual->prox;
            }
            else
            {
                anterior->prox = atual->prox;
            }
            free(atual);
            return Lista;
        }
        anterior = atual;
        atual = atual->prox;
    }
    return Lista;
}


